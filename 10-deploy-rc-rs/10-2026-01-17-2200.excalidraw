      "type": "text",
      "x": 12060,
      "y": 30040,
      "width": 692.99609375,
      "height": 300,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
