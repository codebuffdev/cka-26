      "seed": 196458218,
      "version": 16,
      "versionNonce": 1253301157,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1768722961077,
      "link": null,
      "locked": false,
      "text": "certificate-authority-data : \n→ Which Certificate Authority (CA) to trust for verifying the\nSERVER\n\nserver :\n→ Where the Kubernetes API server is (IP / URL)\n\nclient-certificate-data :\n→ Who the client claims to be (client identity)\n\nclient-key-data :\n→ Proof that the client really owns that identity (private key)",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "certificate-authority-data : \n→ Which Certificate Authority (CA) to trust for verifying the SERVER\n\nserver :\n→ Where the Kubernetes API server is (IP / URL)\n\nclient-certificate-data :\n→ Who the client claims to be (client identity)\n\nclient-key-data :\n→ Proof that the client really owns that identity (private key)",
      "autoResize": false,
      "lineHeight": 1.25
    },
