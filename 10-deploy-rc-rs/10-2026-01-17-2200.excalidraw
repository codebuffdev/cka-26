      "boundElements": [],
      "updated": 1768722961077,
      "link": null,
      "locked": false,
      "text": "kubectl config view\napiVersion: v1\nclusters:\n- cluster:\n    certificate-authority-data: DATA+OMITTED\n    server: https://127.0.0.1:38069\n  name: kind-cka-1.31v\ncontexts:\n- context:\n    cluster: kind-cka-1.31v\n    user: kind-cka-1.31v\n  name: kind-cka-1.31v\ncurrent-context: kind-cka-1.31v\nkind: Config\nusers:\n- name: kind-cka-1.31v\n  user:\n    client-certificate-data: DATA+OMITTED\n    client-key-data: DATA+OMITTED",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "kubectl config view\napiVersion: v1\nclusters:\n- cluster:\n    certificate-authority-data: DATA+OMITTED\n    server: https://127.0.0.1:38069\n  name: kind-cka-1.31v\ncontexts:\n- context:\n    cluster: kind-cka-1.31v\n    user: kind-cka-1.31v\n  name: kind-cka-1.31v\ncurrent-context: kind-cka-1.31v\nkind: Config\nusers:\n- name: kind-cka-1.31v\n  user:\n    client-certificate-data: DATA+OMITTED\n    client-key-data: DATA+OMITTED",
