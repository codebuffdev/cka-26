      "boundElements": null,
      "updated": 1768647017157,
      "link": null,
      "locked": false,
      "text": "| Item               | Role                   |\n| ------------------ | ---------------------- |\n| Client cert        | “Who I am”             |\n| Client private key | “Proof it’s really me” |\n| CA cert            | “Who I trust”          |\n| RBAC               | “What I can do”        |",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "| Item               | Role                   |\n| ------------------ | ---------------------- |\n| Client cert        | “Who I am”             |\n| Client private key | “Proof it’s really me” |\n| CA cert            | “Who I trust”          |\n| RBAC               | “What I can do”        |",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
