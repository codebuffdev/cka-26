      "boundElements": [],
      "updated": 1773640093952,
      "link": null,
      "locked": false,
      "text": "The simplest clusters run a single control plane node & are best suited for labs and\ntesting. \nFor production clusters, you should run three or five control plane nodes and spread\nthem across availability zones for high availability,",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The simplest clusters run a single control plane node & are best suited for labs and testing. \nFor production clusters, you should run three or five control plane nodes and spread them across availability zones for high availability,",
      "autoResize": false,
      "lineHeight": 1.25
    },
