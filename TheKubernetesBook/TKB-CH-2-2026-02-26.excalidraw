    {
      "id": "TkHB1KiL2TSehq4khXnmE",
      "type": "text",
      "x": 6200,
      "y": 4640,
      "width": 583,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
