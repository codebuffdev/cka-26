    {
      "id": "EPm1hSHSQIrst-0MI8pSw",
      "type": "text",
      "x": 920,
      "y": 7720,
      "width": 940.0000000000001,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "c0Yq",
      "roundness": null,
      "seed": 1653177460,
      "version": 44,
      "versionNonce": 1413728118,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1773640093952,
      "link": null,
      "locked": false,
      "text": "Kubernetes abstracts cloud resources and schedules application microservices. ",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Kubernetes abstracts cloud resources and schedules application microservices. ",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "ghWXPiaW5m5Bpi6e2Wz5p",
      "type": "text",
      "x": 900,
      "y": 7780,
      "width": 1034,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "c0Yr",
      "roundness": null,
      "seed": 1105337972,
      "version": 88,
      "versionNonce": 1482101482,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1773640093952,
      "link": null,
      "locked": false,
      "text": "K8s can work with AWS, GCP, on-premise, Hybrid cloud, Multi-cloud, Cloud migrations : cloud OS",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "K8s can work with AWS, GCP, on-premise, Hybrid cloud, Multi-cloud, Cloud migrations : cloud OS",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "o-4BjJC6JyB0yFFU8G6II",
      "type": "text",
      "x": 900,
      "y": 7840,
      "width": 847,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "c0Ys",
      "roundness": null,
      "seed": 1584155468,
      "version": 236,
      "versionNonce": 1250388150,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1773640093952,
      "link": null,
      "locked": false,
      "text": "Application Scheduling :\n1. OS helps, computer hardware resources (CPU, Storage, network) are complex.\n2. OS assign it & make our job easy by hiding complexity. ",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Application Scheduling :\n1. OS helps, computer hardware resources (CPU, Storage, network) are complex.\n2. OS assign it & make our job easy by hiding complexity. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "c8xxu1iaLW7wBbp2MFwzf",
      "type": "text",
      "x": 900,
      "y": 7960,
      "width": 1120,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "c0Yt",
      "roundness": null,
      "seed": 1672018508,
      "version": 127,
      "versionNonce": 310977962,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1773640093952,
      "link": null,
      "locked": false,
      "text": "Kubernetes does similar things with clouds & data centers. \nCloud or data center is a complex collection of resources & services. \nKubernetes abstracts most of this, making the resources easier to consume. (AT A HIGH LEVEL) \n(CLOUD OS FOR A REASON)",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Kubernetes does similar things with clouds & data centers. \nCloud or data center is a complex collection of resources & services. \nKubernetes abstracts most of this, making the resources easier to consume. (AT A HIGH LEVEL) \n(CLOUD OS FOR A REASON)",
      "autoResize": false,
      "lineHeight": 1.25
    },
