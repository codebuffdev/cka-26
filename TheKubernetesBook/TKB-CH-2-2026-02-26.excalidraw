    {
      "id": "m4MKiEMWyQuU_U0y8FIpG",
      "type": "text",
      "x": 900,
      "y": 8160,
      "width": 791.99951171875,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
