      "updated": 1773640143640,
      "link": null,
      "locked": false,
      "text": "Pod is also an atomic operation\nPod is ready when all containers are up and running. \nAll the containers all scheduled in a same node",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Pod is also an atomic operation\nPod is ready when all containers are up and running. \nAll the containers all scheduled in a same node",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "NPyMmuijxf1Oeh2kz3vFd",
      "type": "text",
      "x": 6200,
      "y": 4780,
      "width": 451,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
