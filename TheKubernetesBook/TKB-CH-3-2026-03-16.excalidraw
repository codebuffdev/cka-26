    {
      "id": "85JuvUI_EMvPmq3cp1xM0",
      "type": "text",
      "x": 2140,
      "y": 4060,
      "width": 715,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
