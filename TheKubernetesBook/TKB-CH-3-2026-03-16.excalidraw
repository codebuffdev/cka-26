      "index": "c0c6",
      "roundness": null,
      "seed": 1462598409,
      "version": 102,
      "versionNonce": 33530445,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1773640143640,
      "link": null,
      "locked": false,
      "text": "Pods are mortal —\n they’re created, they live, and they die\n old pod replaced by new \n    new IP address allocated ",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Pods are mortal —\n they’re created, they live, and they die\n old pod replaced by new \n    new IP address allocated ",
      "autoResize": true,
      "lineHeight": 1.25
    },
