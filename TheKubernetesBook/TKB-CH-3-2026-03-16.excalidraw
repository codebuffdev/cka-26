      "index": "c0Zz",
      "roundness": null,
      "seed": 2076441578,
      "version": 181,
      "versionNonce": 1285895277,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1773640143639,
      "link": null,
      "locked": false,
      "text": "Cluster can have both windows/Linux w.node.\n1. Most cloud cloud-native apps are Linux apps -> Linux w.node\n2. If the cloud-native apps is windows apps    -> Windows w.node ",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Cluster can have both windows/Linux w.node.\n1. Most cloud cloud-native apps are Linux apps -> Linux w.node\n2. If the cloud-native apps is windows apps    -> Windows w.node ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "pFo2WUGH-NJ9wbkUwT9ql",
      "type": "text",
      "x": 2180,
      "y": 4160,
      "width": 539,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "c0a0",
      "roundness": null,
      "seed": 933172714,
      "version": 133,
      "versionNonce": 583554275,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1773640143639,
      "link": null,
      "locked": false,
      "text": "k8s is intelligent enough to schedule \nlinux app on linux w.node & same for windows app.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "k8s is intelligent enough to schedule \nlinux app on linux w.node & same for windows app.",
      "autoResize": true,
      "lineHeight": 1.25
    },
