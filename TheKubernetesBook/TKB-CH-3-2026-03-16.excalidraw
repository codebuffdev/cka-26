      "isDeleted": true,
      "boundElements": [],
      "updated": 1773640143639,
      "link": null,
      "locked": false,
      "text": "etcd distributed database\netcd replica on every control plane node for HA\nin HA env also we need backup and recovery\netcd distributed databases so for write consistency it uses RAFT consensus algorithm.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "etcd distributed database\netcd replica on every control plane node for HA\nin HA env also we need backup and recovery\netcd distributed databases so for write consistency it uses RAFT consensus algorithm.",
      "autoResize": true,
      "lineHeight": 1.25
    },
