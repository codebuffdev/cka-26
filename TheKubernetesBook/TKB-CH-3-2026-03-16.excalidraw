    {
      "id": "P4lhXRWbpMpgF6YW4Ua33",
      "type": "text",
      "x": 2160.8662496490088,
      "y": 4321.059823518508,
      "width": 429,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "c0a2",
      "roundness": null,
      "seed": 1226052662,
      "version": 67,
      "versionNonce": 1968291971,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1773640143639,
      "link": null,
      "locked": false,
      "text": "Brain of K8s cluster. \nIt is a collection of system services .",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Brain of K8s cluster. \nIt is a collection of system services .",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Ubgjt0n48rpTG9dKQpPIk",
      "type": "text",
      "x": 2160,
      "y": 4400,
      "width": 940,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "c0a7",
      "roundness": null,
      "seed": 456261098,
      "version": 48,
      "versionNonce": 302693677,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1773640143639,
      "link": null,
      "locked": false,
      "text": "The simplest clusters run a single control plane node & are best suited for labs and\ntesting. \nFor production clusters, you should run three or five control plane nodes and spread\nthem across availability zones for high availability,",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The simplest clusters run a single control plane node & are best suited for labs and testing. \nFor production clusters, you should run three or five control plane nodes and spread them across availability zones for high availability,",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "CVDENEVT7NXkOOit-tqJ2",
      "type": "text",
      "x": 2160,
      "y": 4520,
      "width": 800.0000000000001,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "c0aA",
      "roundness": null,
      "seed": 1631832682,
      "version": 33,
      "versionNonce": 1995225123,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1773640143639,
      "link": null,
      "locked": false,
      "text": "Run every control plane service on every control plane node for HA. ",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Run every control plane service on every control plane node for HA. ",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "OA4KrLO-xFh6dqfGGlyR_",
      "type": "text",
      "x": 2160.8661580962744,
      "y": 4563.459725862258,
      "width": 451,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "c0aB",
      "roundness": null,
      "seed": 163422826,
      "version": 159,
      "versionNonce": 1165266829,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1773640143639,
      "link": null,
      "locked": false,
      "text": "Job of the control plane\n1. expose api -> kube api server\n2. schedules apps -> Schedular\n3. implements self-healing -> Controllers\n4. manages scaling -> RsControllers\netc.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Job of the control plane\n1. expose api -> kube api server\n2. schedules apps -> Schedular\n3. implements self-healing -> Controllers\n4. manages scaling -> RsControllers\netc.",
      "autoResize": true,
      "lineHeight": 1.25
    },
