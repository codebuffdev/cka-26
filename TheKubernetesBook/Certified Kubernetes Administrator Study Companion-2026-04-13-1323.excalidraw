      "isDeleted": false,
      "boundElements": [],
      "updated": 1776311924384,
      "link": null,
      "locked": false,
      "text": "Solution Manual Intervention \nBut not sustainable in all cases\n1. 24/7 across global time zones\n2. support teams Increases operational costs \n3. Limited ability to handle multiple simultaneous failures",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Solution Manual Intervention \nBut not sustainable in all cases\n1. 24/7 across global time zones\n2. support teams Increases operational costs \n3. Limited ability to handle multiple simultaneous failures",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "z0ICekyXJT8tSECe3YaXU",
