      "isDeleted": false,
      "boundElements": [],
      "updated": 1776311924384,
      "link": null,
      "locked": false,
      "text": "1. Few containers \n2. simple application minimal scaling \n3. tight infra budget ",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Few containers \n2. simple application minimal scaling \n3. tight infra budget ",
