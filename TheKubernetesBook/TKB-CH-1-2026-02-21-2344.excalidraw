    {
      "id": "m4MKiEMWyQuU_U0y8FIpG",
      "type": "text",
      "x": 900,
      "y": 8160,
      "width": 791.99951171875,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "c0R3",
      "roundness": null,
      "seed": 1534204276,
      "version": 97,
      "versionNonce": 1200014540,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1771698619015,
      "link": null,
      "locked": false,
      "text": "1. Kubernetes was created by Google engineers.\n2. They donated it to the community as an open-source project  \n3. It runs on any cloud or on-premises data center & abstracts the\nunderlying infrastructure. This allows you to build hybrid clouds, as\nwell as migrate on, off, & between different clouds. \n4. It’s open-sourced under the Apache 2.0 license & is owned and\nmanaged by the Cloud Native Computing Foundation (CNCF).",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Kubernetes was created by Google engineers.\n2. They donated it to the community as an open-source project  \n3. It runs on any cloud or on-premises data center & abstracts the underlying infrastructure. This allows you to build hybrid clouds, as well as migrate on, off, & between different clouds. \n4. It’s open-sourced under the Apache 2.0 license & is owned and managed by the Cloud Native Computing Foundation (CNCF).",
      "autoResize": false,
      "lineHeight": 1.25
    },
