    {
      "id": "EPm1hSHSQIrst-0MI8pSw",
      "type": "text",
      "x": 900,
      "y": 7720,
      "width": 940.0000000000001,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "c0RH",
      "roundness": null,
      "seed": 1653177460,
      "version": 40,
      "versionNonce": 1766970466,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773574068393,
      "link": null,
      "locked": false,
      "text": "Kubernetes abstracts cloud resources and schedules application microservices. ",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Kubernetes abstracts cloud resources and schedules application microservices. ",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "ghWXPiaW5m5Bpi6e2Wz5p",
      "type": "text",
      "x": 900,
      "y": 7780,
      "width": 1034,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "c0RI",
      "roundness": null,
      "seed": 1105337972,
      "version": 83,
      "versionNonce": 980423570,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772111759252,
      "link": null,
      "locked": false,
      "text": "K8s can work with AWS, GCP, on-premise, Hybrid cloud, Multi-cloud, Cloud migrations : cloud OS",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "K8s can work with AWS, GCP, on-premise, Hybrid cloud, Multi-cloud, Cloud migrations : cloud OS",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "o-4BjJC6JyB0yFFU8G6II",
      "type": "text",
      "x": 900,
      "y": 7840,
      "width": 847,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "c0RJ",
      "roundness": null,
      "seed": 1584155468,
      "version": 231,
      "versionNonce": 1034131148,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1771698740202,
      "link": null,
      "locked": false,
      "text": "Application Scheduling :\n1. OS helps, computer hardware resources (CPU, Storage, network) are complex.\n2. OS assign it & make our job easy by hiding complexity. ",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Application Scheduling :\n1. OS helps, computer hardware resources (CPU, Storage, network) are complex.\n2. OS assign it & make our job easy by hiding complexity. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "c8xxu1iaLW7wBbp2MFwzf",
      "type": "text",
      "x": 900,
      "y": 7960,
      "width": 1120,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "c0RK",
      "roundness": null,
      "seed": 1672018508,
      "version": 122,
      "versionNonce": 154784628,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1771698861081,
      "link": null,
      "locked": false,
      "text": "Kubernetes does similar things with clouds & data centers. \nCloud or data center is a complex collection of resources & services. \nKubernetes abstracts most of this, making the resources easier to consume. (AT A HIGH LEVEL) \n(CLOUD OS FOR A REASON)",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Kubernetes does similar things with clouds & data centers. \nCloud or data center is a complex collection of resources & services. \nKubernetes abstracts most of this, making the resources easier to consume. (AT A HIGH LEVEL) \n(CLOUD OS FOR A REASON)",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "ZkCoRjImq8zvV_-2RRFL8",
      "type": "rectangle",
      "x": 1600,
      "y": 3020,
      "width": 240,
      "height": 80,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
